          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "It looks like "
              },
              {
                "type": "text",
                "text": "net.minecraft.client.gui.components.AbstractWidget#isMouseOver",
                "marks": [
                  {
                    "type": "code"
